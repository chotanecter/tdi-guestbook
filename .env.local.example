# Copy this file to .env.local and fill in your Supabase project values

# From Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# Only used server-side. NEVER expose in client code.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Brand + site
NEXT_PUBLIC_SITE_NAME=Technically Doing It
NEXT_PUBLIC_SITE_URL=https://tdi-guestbook.vercel.app

# Set to your admin email (used to gate the /admin page)
ADMIN_EMAIL=you@example.com
